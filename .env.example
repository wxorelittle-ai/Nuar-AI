# ── РестоПульс · Competitor Scraper Agent ─────────────────────────────
# Скопируйте файл в .env и заполните значения. .env в git НЕ коммитится.

# ── Telegram (обязательно для отправки дайджеста) ─────────────────────
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=
# ID чата/канала управляющего, куда слать дайджест (число или @username канала)
TELEGRAM_CHAT_ID=

# ── VK API (обязательно для сбора данных VK) ──────────────────────────
# Сервисный ключ доступа приложения VK (https://dev.vk.com)
VK_SERVICE_TOKEN=
# Версия VK API
VK_API_VERSION=5.199

# ── Безопасность панели (ОБЯЗАТЕЛЬНО на сервере) ──────────────────────
# Пароль входа в панель. Если пусто — вход открыт (только для локальной разработки!).
ADMIN_PASSWORD=
# Секрет для подписи сессий. Задайте длинную случайную строку на сервере.
# Если пусто — сгенерируется и сохранится в data/.secret.
SECRET_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────
# Если пусто — локальный режим на JSON-файлах (data/*.json).
# В docker-compose DATABASE_URL задаётся автоматически, здесь можно оставить пусто.
# Формат: postgresql://user:password@host:5432/metr
DATABASE_URL=
# Пароль пользователя БД для docker-compose (сервис db)
POSTGRES_PASSWORD=metr

# ── Адрес сайта (Caddy · HTTPS) ───────────────────────────────────────
# Домен → автоматический HTTPS (сертификат Let's Encrypt), напр. metr.example.ru
# :80    → доступ по IP без шифрования (только для первичной проверки, не для боевого)
METR_SITE_ADDRESS=:80

# ── 2ГИС (опционально, для стабильного сбора) ─────────────────────────
# Ключ 2GIS Catalog API. Без него используется best-effort HTML-парсинг.
DGIS_API_KEY=

# ── Яндекс.Карты (опционально, для стабильного сбора) ─────────────────
# Ключ Yandex Geosearch/Places API.
YANDEX_API_KEY=

# ── HeadHunter (рекрутинг «Мэтр нанимает») ────────────────────────────
# HH закрыл анонимный поиск вакансий. Зарегистрируйте бесплатное приложение
# на https://dev.hh.ru/admin и вставьте client_id / client_secret.
HH_CLIENT_ID=
HH_CLIENT_SECRET=

# ── Поведение краулера ────────────────────────────────────────────────
# Пауза между HTTP-запросами, сек (антифлуд, уважение к источникам)
REQUEST_DELAY_SEC=2.0
# Таймаут HTTP-запроса, сек
REQUEST_TIMEOUT_SEC=20
# User-Agent для запросов
HTTP_USER_AGENT=RestoPulseBot/0.1 (+https://nuar.example; monitoring)

# ── Расписание ────────────────────────────────────────────────────────
# CRON расписания еженедельного дайджеста (по умолч. пн 09:00)
DIGEST_CRON_DAY_OF_WEEK=mon
DIGEST_CRON_HOUR=9
DIGEST_CRON_MINUTE=0
# Часовой пояс планировщика
TIMEZONE=Asia/Yekaterinburg
