# ── Секреты — НИКОГДА не коммитить ───────────────────────────────────
.env
data/.secret

# виртуальные окружения
.venv/
venv/

# ── Локальные данные (создаются на сервере/в проде) ──────────────────
# содержимое data/ игнорируем, но сам каталог сохраняем через .gitkeep
data/*
!data/.gitkeep

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/

# ── IDE / ОС ──────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
